{"Year":[2015,2016,2017,2018,2019,2020,2021,2022,2023],"Units":["\u043c\u0438\u043b\u043b\u0438\u043e\u043d \u0434\u043e\u043b\u043b\u0430\u0440\u043e\u0432 \u0421\u0428\u0410","\u043c\u0438\u043b\u043b\u0438\u043e\u043d \u0434\u043e\u043b\u043b\u0430\u0440\u043e\u0432 \u0421\u0428\u0410","\u043c\u0438\u043b\u043b\u0438\u043e\u043d \u0434\u043e\u043b\u043b\u0430\u0440\u043e\u0432 \u0421\u0428\u0410","\u043c\u0438\u043b\u043b\u0438\u043e\u043d \u0434\u043e\u043b\u043b\u0430\u0440\u043e\u0432 \u0421\u0428\u0410","\u043c\u0438\u043b\u043b\u0438\u043e\u043d \u0434\u043e\u043b\u043b\u0430\u0440\u043e\u0432 \u0421\u0428\u0410","\u043c\u0438\u043b\u043b\u0438\u043e\u043d \u0434\u043e\u043b\u043b\u0430\u0440\u043e\u0432 \u0421\u0428\u0410","\u043c\u0438\u043b\u043b\u0438\u043e\u043d \u0434\u043e\u043b\u043b\u0430\u0440\u043e\u0432 \u0421\u0428\u0410","\u043c\u0438\u043b\u043b\u0438\u043e\u043d \u0434\u043e\u043b\u043b\u0430\u0440\u043e\u0432 \u0421\u0428\u0410","\u043c\u0438\u043b\u043b\u0438\u043e\u043d \u0434\u043e\u043b\u043b\u0430\u0440\u043e\u0432 \u0421\u0428\u0410"],"\u041a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u044f":["\u041f\u043e\u043a\u0430\u0437\u0430\u0442\u0435\u043b\u044c 2.a.2, \u041e\u0431\u0449\u0438\u0439 \u043e\u0431\u044a\u0435\u043c \u043e\u0444\u0438\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0445 \u043f\u043e\u0442\u043e\u043a\u043e\u0432 (\u0432\u044b\u043f\u043b\u0430\u0442) \u043d\u0430 \u043d\u0443\u0436\u0434\u044b \u0441\u0435\u043b\u044c\u0441\u043a\u043e\u0433\u043e \u0445\u043e\u0437\u044f\u0439\u0441\u0442\u0432\u0430 \u043f\u043e \u0441\u0442\u0440\u0430\u043d\u0430\u043c-\u043f\u043e\u043b\u0443\u0447\u0430\u0442\u0435\u043b\u044f\u043c (\u0432 \u043c\u0438\u043b\u043b\u0438\u043e\u043d\u0430\u0445 \u0434\u043e\u043b\u043b\u0430\u0440\u043e\u0432 \u0421\u0428\u0410 \u0432 \u043f\u043e\u0441\u0442\u043e\u044f\u043d\u043d\u044b\u0445 \u0446\u0435\u043d\u0430\u0445 2023 \u0433\u043e\u0434\u0430)","\u041f\u043e\u043a\u0430\u0437\u0430\u0442\u0435\u043b\u044c 2.a.2, \u041e\u0431\u0449\u0438\u0439 \u043e\u0431\u044a\u0435\u043c \u043e\u0444\u0438\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0445 \u043f\u043e\u0442\u043e\u043a\u043e\u0432 (\u0432\u044b\u043f\u043b\u0430\u0442) \u043d\u0430 \u043d\u0443\u0436\u0434\u044b \u0441\u0435\u043b\u044c\u0441\u043a\u043e\u0433\u043e \u0445\u043e\u0437\u044f\u0439\u0441\u0442\u0432\u0430 \u043f\u043e \u0441\u0442\u0440\u0430\u043d\u0430\u043c-\u043f\u043e\u043b\u0443\u0447\u0430\u0442\u0435\u043b\u044f\u043c (\u0432 \u043c\u0438\u043b\u043b\u0438\u043e\u043d\u0430\u0445 \u0434\u043e\u043b\u043b\u0430\u0440\u043e\u0432 \u0421\u0428\u0410 \u0432 \u043f\u043e\u0441\u0442\u043e\u044f\u043d\u043d\u044b\u0445 \u0446\u0435\u043d\u0430\u0445 2023 \u0433\u043e\u0434\u0430)","\u041f\u043e\u043a\u0430\u0437\u0430\u0442\u0435\u043b\u044c 2.a.2, \u041e\u0431\u0449\u0438\u0439 \u043e\u0431\u044a\u0435\u043c \u043e\u0444\u0438\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0445 \u043f\u043e\u0442\u043e\u043a\u043e\u0432 (\u0432\u044b\u043f\u043b\u0430\u0442) \u043d\u0430 \u043d\u0443\u0436\u0434\u044b \u0441\u0435\u043b\u044c\u0441\u043a\u043e\u0433\u043e \u0445\u043e\u0437\u044f\u0439\u0441\u0442\u0432\u0430 \u043f\u043e \u0441\u0442\u0440\u0430\u043d\u0430\u043c-\u043f\u043e\u043b\u0443\u0447\u0430\u0442\u0435\u043b\u044f\u043c (\u0432 \u043c\u0438\u043b\u043b\u0438\u043e\u043d\u0430\u0445 \u0434\u043e\u043b\u043b\u0430\u0440\u043e\u0432 \u0421\u0428\u0410 \u0432 \u043f\u043e\u0441\u0442\u043e\u044f\u043d\u043d\u044b\u0445 \u0446\u0435\u043d\u0430\u0445 2023 \u0433\u043e\u0434\u0430)","\u041f\u043e\u043a\u0430\u0437\u0430\u0442\u0435\u043b\u044c 2.a.2, \u041e\u0431\u0449\u0438\u0439 \u043e\u0431\u044a\u0435\u043c \u043e\u0444\u0438\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0445 \u043f\u043e\u0442\u043e\u043a\u043e\u0432 (\u0432\u044b\u043f\u043b\u0430\u0442) \u043d\u0430 \u043d\u0443\u0436\u0434\u044b \u0441\u0435\u043b\u044c\u0441\u043a\u043e\u0433\u043e \u0445\u043e\u0437\u044f