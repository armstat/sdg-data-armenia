{"Year":[2010,2016,2020,2022,2010,2016,2020,2022,2010,2016,2020,2022,2010,2016,2020,2022],"\u0551\u0578\u0582\u0581\u0561\u0576\u056b\u0577":["\u053b\u0576\u057e\u0561\u0566\u056b\u057e \u0585\u057f\u0561\u0580 \u057f\u0565\u057d\u0561\u056f\u0576\u0565\u0580\u056b \u0576\u0565\u0580\u0574\u0578\u0582\u056e\u0574\u0561\u0576 \u056f\u0561\u0576\u056d\u0561\u0580\u0563\u0565\u056c\u0574\u0561\u0576 \u0587 \u056f\u0561\u057c\u0561\u057e\u0561\u0580\u0574\u0561\u0576 \u057e\u0565\u0580\u0561\u0562\u0565\u0580\u0575\u0561\u056c \u0585\u0580\u0565\u0576\u057d\u0564\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576, \u056f\u0561\u0576\u0578\u0576\u0561\u056f\u0561\u0580\u0563, \u0585\u0580\u0565\u0576\u0584","\u053b\u0576\u057e\u0561\u0566\u056b\u057e \u0585\u057f\u0561\u0580 \u057f\u0565\u057d\u0561\u056f\u0576\u0565\u0580\u056b \u0576\u0565\u0580\u0574\u0578\u0582\u056e\u0574\u0561\u0576 \u056f\u0561\u0576\u056d\u0561\u0580\u0563\u0565\u056c\u0574\u0561\u0576 \u0587 \u056f\u0561\u057c\u0561\u057e\u0561\u0580\u0574\u0561\u0576 \u057e\u0565\u0580\u0561\u0562\u0565\u0580\u0575\u0561\u056c \u0585\u0580\u0565\u0576\u057d\u0564\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576, \u056f\u0561\u0576\u0578\u0576\u0561\u056f\u0561\u0580\u0563, \u0585\u0580\u0565\u0576\u0584","\u053b\u0576\u057e\u0561\u0566\u056b\u057e \u0585\u057f\u0561\u0580 \u057f\u0565\u057d\u0561\u056f\u0576\u0565\u0580\u056b \u0576\u0565\u0580\u0574\u0578\u0582\u056e\u0574\u0561\u0576 \u056f\u0561\u0576\u056d\u0561\u0580\u0563\u0565\u056c\u0574\u0561\u0576 \u0587 \u056f\u0561\u057c\u0561\u057e\u0561\u0580\u0574\u0561\u0576 \u057e\u0565\u0580\u0561\u0562\u0565\u0580\u0575\u0561\u056c \u0585\u0580\u0565\u0576\u057d\u0564\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576, \u056f\u0561\u0576\u0578\u0576\u0561\u056f\u0561\u0580\u0563, \u0585\u0580\u0565\u0576\u0584","\u053b\u0576\u057e\u0561\u0566\u056b\u057e \u0585\u057f\u0561\u0580 \u057f\u0565\u057d\u0561\u056f\u0576\u0565\u0580\u056b \u0576\u0565\u0580\u0574\u0578\u0